# WC3 Roadmap — environment variable template
# Copy this file to .env.local and fill in real values. Never commit .env.local.
# See .planning/phases/04-auth-database/04-RESEARCH.md §"OSS Contributor Dev DB Recommendation"
# for setup instructions.

# ---------------------------------------------------------------------------
# Authentication (better-auth)
# ---------------------------------------------------------------------------

# Random secret used to sign sessions and tokens.
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Public URL of the app. Used by better-auth to build callback URLs.
# Dev: http://localhost:3000  |  Prod: https://<your-vercel-domain>
BETTER_AUTH_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Battle.net OAuth (Blizzard Developer Portal)
# https://develop.battle.net/access/clients
# ---------------------------------------------------------------------------

# Client ID — from your Battle.net OAuth client page.
# Dashboard: https://develop.battle.net/access/clients → your client → Client ID
BNET_CLIENT_ID=

# Client Secret — from the same Battle.net OAuth client page.
# Keep this private; never share or commit.
BNET_CLIENT_SECRET=

# Required redirect URIs to configure on the Battle.net OAuth client:
#   Dev:  http://localhost:3000/api/auth/callback/battlenet
#   Prod: https://<vercel-domain>/api/auth/callback/battlenet

# ---------------------------------------------------------------------------
# Neon PostgreSQL (https://console.neon.tech)
# ---------------------------------------------------------------------------

# Pooled connection string (pgbouncer) — used by the app at runtime.
# Neon Console → Your project → Connection string (Pooled) → dev branch
DATABASE_URL=

# Direct (non-pooled) connection string — used by drizzle-kit for migrations.
# Neon Console → Connection string → "Direct connection" toggle → dev branch
# See drizzle.config.ts for why this MUST be non-pooled (RESEARCH Pitfall 5).
DATABASE_URL_DIRECT=

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------

# Public app URL, exposed to the client via Vite.
# Dev: http://localhost:3000  |  Prod: https://<your-vercel-domain>
VITE_APP_URL=http://localhost:3000
